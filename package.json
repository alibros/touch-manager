{
  "name": "touch-manager",
  "private": true,
  "version": "0.1.0",
  "description": "A safe firmware library, installer, and diagnostic console for Synthux Touch 2.",
  "license": "MIT",
  "author": "Ali Bross",
  "keywords": ["synthux", "touch-2", "firmware", "dfu", "tauri"],
  "engines": {
    "node": ">=20.19"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
